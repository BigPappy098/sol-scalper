# ============================================================
# SOL Scalper - Environment Variables
# ============================================================
# Set these as RunPod Environment Variables when creating the pod,
# or create a .env file in the project root.

# Trading mode: paper or live
TRADING_MODE=paper

# Hyperliquid wallet credentials
# Generate a new wallet or use an existing one
# Paper: use testnet (api.hyperliquid-testnet.xyz)
# Live: use mainnet (api.hyperliquid.xyz)
HL_PRIVATE_KEY=0x_your_wallet_private_key
HL_WALLET_ADDRESS=0x_your_wallet_address

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# LLM for self-improvement agent (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Trading parameters (defaults shown)
SYMBOL=SOL
RISK_PER_TRADE=0.01
MAX_LEVERAGE=5.0

# Database & Redis (no need to change — runs locally in container)
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/scalper
REDIS_URL=redis://localhost:6379
